<Project Sdk="Aiursoft.Apkg.Sdk">
  <PropertyGroup>
    <PackageName>gnome-shell-extension-anduinos-switcher</PackageName>
    <PackageVersion>2.0.0</PackageVersion>
    <Maintainer>AnduinOS Team &lt;anduin@aiursoft.com&gt;</Maintainer>
    <PackageDescription>AnduinOS Light/Dark Theme Switcher GNOME Shell extension (switcher@anduinos)</PackageDescription>
    <PackageHomepage>https://www.anduinos.com</PackageHomepage>
    <LicenseType>GPL-2.0</LicenseType>
    <TargetDistro>anduinos</TargetDistro>
    <TargetSuites>noble-addon questing-addon resolute-addon</TargetSuites>
    <TargetArchitectures>all</TargetArchitectures>
    <Component>main</Component>
  </PropertyGroup>

  <ItemGroup>
    <IncludeFolder Include="deploy/noble/switcher@anduinos"
                   Target="/usr/share/gnome-shell/extensions/switcher@anduinos"
                   Condition="'$(Suite)' == 'noble-addon'" />
    <IncludeFolder Include="deploy/questing/switcher@anduinos"
                   Target="/usr/share/gnome-shell/extensions/switcher@anduinos"
                   Condition="'$(Suite)' == 'questing-addon'" />
    <IncludeFolder Include="deploy/resolute/switcher@anduinos"
                   Target="/usr/share/gnome-shell/extensions/switcher@anduinos"
                   Condition="'$(Suite)' == 'resolute-addon'" />
  </ItemGroup>
</Project>
